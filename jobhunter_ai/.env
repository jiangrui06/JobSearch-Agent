# ==================== JobHunter AI 环境配置 ====================

# ---- AI API 配置（至少配置一个） ----
# 阿里云通义千问（百炼平台 OpenAI 兼容接口）
DEEPSEEK_API_KEY="sk-8eb8a8346edd447795011ce233ceaa0d"
DEEPSEEK_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
# Anthropic Claude API Key
ANTHROPIC_API_KEY=""
# OpenAI API Key
OPENAI_API_KEY=""
# 模型选择: deepseek / anthropic / openai
AI_PROVIDER="deepseek"
# 模型名称（qwen-plus / qwen-max / qwen-turbo）
AI_MODEL="qwen-plus"

# ---- 简历路径 ----
# 支持 .pdf 或 .txt 格式
RESUME_PATH=""

# ---- 求职偏好 ----
# 搜索关键词（逗号分隔多个）
SEARCH_KEYWORDS="Python开发,机器学习,数据挖掘"
# 目标城市
SEARCH_CITY="上海"
# 期望薪资（可选，如 "30-50万/年"）
SALARY_EXPECTATION=""

# ---- 爬虫配置 ----
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1.0
# 请求间随机延时范围（秒）
MIN_DELAY=1.0
MAX_DELAY=3.0
# 代理配置
PROXY_ENABLED=false
PROXY_URL=""
# 浏览器模式（BOSS直聘爬虫使用）
# true=弹出浏览器窗口，可手动完成验证码；false=静默无界面
SHOW_BROWSER=true

# ---- 输出配置 ----
TOP_N_RESULTS=10
SAVE_CSV=true
GENERATE_CHART=true

# ---- 日志配置 ----
LOG_LEVEL="INFO"
