# ==================== JobHunter AI 环境配置模板 ====================
# 复制本文件为 .env 后填写真实值

# ---- AI API 配置（必填，支持任何 OpenAI 兼容接口） ----
# 先声科技 SenseNova
DEEPSEEK_API_KEY="sk-你的API密钥"
DEEPSEEK_API_BASE="https://token.sensenova.cn/v1"
AI_PROVIDER="sensenova"
AI_MODEL="sensenova-6.7-flash-lite"

# 其他可选示例：
# DeepSeek
# DEEPSEEK_API_KEY="sk-你的API密钥"
# DEEPSEEK_API_BASE="https://api.deepseek.com"
# AI_PROVIDER="deepseek"
# AI_MODEL="deepseek-chat"

# 通义千问（阿里云百炼）
# DEEPSEEK_API_KEY="sk-你的API密钥"
# DEEPSEEK_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
# AI_PROVIDER="qwen"
# AI_MODEL="qwen-plus"

# ---- 简历路径（必填） ----
# 建议放在项目内：data/resumes/你的简历.docx
# Windows 可用正斜杠避免转义问题
RESUME_PATH="data/resumes/你的简历.docx"

# ---- 求职偏好 ----
SEARCH_KEYWORDS="Python开发,机器学习,数据挖掘"
SEARCH_CITY="上海"
# 可选：如 "30-50万/年"
SALARY_EXPECTATION=""

# ---- 爬虫配置 ----
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=1.0
MIN_DELAY=1.0
MAX_DELAY=3.0
PROXY_ENABLED=false
PROXY_URL=""
# true=弹出浏览器窗口（可手动扫码）；false=静默无界面
SHOW_BROWSER=true

# ---- 性能调优 ----
MAX_WORKERS=3

# ---- 输出配置 ----
TOP_N_RESULTS=10
SAVE_CSV=true
GENERATE_CHART=true

# ---- 日志配置 ----
LOG_LEVEL="INFO"
